{
  "_note": "DEPRECATED: リジェクト済み実験専用。本番設定は train_config.json を参照",
  "training": {
    "objective": "binary",
    "metric": "binary_logloss",
    "learning_rate": 0.05,
    "num_leaves": 63,
    "min_child_samples": 30,
    "subsample": 0.8,
    "colsample_bytree": 0.8,
    "reg_alpha": 0.1,
    "reg_lambda": 1.0,
    "device": "cuda",
    "gpu_platform_id": 0,
    "gpu_device_id": 0,
    "gpu_use_dp": false,
    "force_row_wise": true,
    "n_estimators": 1000,
    "early_stopping_rounds": 50,
    "seed": 42,
    "n_trials": 25,
    "_comment_n_trials": "test/実験モード(特徴量A/B比較)の Optuna 試行数。production_training.experiment_n_trials=25 と同一ポリシー。本番 rank は production_training.n_trials=50。binary は backtest_n_trials=0 固定。",
    "verbose": -1,
    "base_margin_col": "market_log_odds",
    "kelly_fraction": 0.08,
    "max_bet_ratio": 0.05,
    "ev_threshold": 1.05,
    "min_odds": 2.0,
    "max_odds": 50.0,
    "min_model_prob": 0.05,
    "walkforward_folds": [
      {
        "fold": 1,
        "train_end": "2021-12-31",
        "valid_start": "2022-01-01",
        "valid_end": "2022-12-31",
        "test_start": "2023-01-01",
        "test_end": "2023-12-31"
      },
      {
        "fold": 2,
        "train_end": "2022-12-31",
        "valid_start": "2023-01-01",
        "valid_end": "2023-12-31",
        "test_start": "2024-01-01",
        "test_end": "2024-12-31"
      },
      {
        "fold": 3,
        "train_end": "2023-12-31",
        "valid_start": "2024-01-01",
        "valid_end": "2024-12-31",
        "test_start": "2025-01-01",
        "test_end": "2025-12-31"
      }
    ],
    "exclude_grade_codes": [
      8,
      9
    ],
    "exclude_abnormal_codes": [
      1,
      3,
      4
    ],
    "min_horse_count": 5,
    "use_group_softmax": false,
    "calibration": {
      "method": "isotonic",
      "temperature": 1.0,
      "temperature_tune": false
    }
  },
  "features": {
    "basic": [
      "horse_age",
      "carry_weight",
      "gate_number",
      "horse_count",
      "days_since_last_race",
      "weight_diff",
      "weight_diff_trend",
      "class_change",
      "draw_bias_score",
      "surface_code",
      "distance",
      "track_condition_code",
      "horse_sex_code",
      "market_prob"
    ],
    "past": [
      "last3_agari3f_mean",
      "last5_rank_mean",
      "last5_time_diff_mean",
      "career_win_rate",
      "distance_win_rate",
      "course_win_rate",
      "surface_win_rate",
      "condition_win_rate",
      "jockey_30d_win_rate",
      "trainer_30d_win_rate",
      "jockey_course_win_rate",
      "sire_surface_win_rate",
      "bms_win_rate"
    ],
    "v2_extended": [
      "ema_rank",
      "ema_time_diff",
      "rpr_score",
      "corner_pos_mean",
      "corner_pos_last",
      "running_style_mode",
      "front_rate",
      "race_front_count",
      "race_front_ratio",
      "race_style_entropy",
      "pci_past_mean",
      "agari_z_score",
      "race_pci",
      "gate_surface_cross",
      "summer_mare_sin",
      "summer_mare_cos",
      "past_speed_index_mean",
      "jra_tm_score",
      "jra_tm_rank",
      "jra_dm_rank",
      "jra_dm_gap_to_best",
      "jra_dm_uncertainty",
      "jra_tm_orthogonalized",
      "weight_relative_z",
      "jockey_trainer_synergy"
    ]
  },
  "db": {
    "path": "common/data/JVData.db"
  }
}